{
  "name": "@jasonshimmy/cer-material",
  "version": "0.5.0",
  "description": "Material Design 3 web components built on @jasonshimmy/custom-elements-runtime",
  "type": "module",
  "keywords": [
    "web-components",
    "custom-elements",
    "reactive",
    "typescript",
    "frontend",
    "ui"
  ],
  "author": "Jason Shimkoski <https://jasonshimmy.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jshimkoski/cer-material.git"
  },
  "homepage": "https://github.com/jshimkoski/cer-material#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "vite build --mode lib",
    "build:cdn": "vite build --mode cdn",
    "build:all": "npm run build:lib && npm run build:cdn",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "@jasonshimmy/custom-elements-runtime": ">=3.0.0"
  },
  "devDependencies": {
    "@jasonshimmy/custom-elements-runtime": "^3.7.4",
    "@types/node": "^25.5.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
